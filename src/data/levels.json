{
  "game": {
    "title": "Blastian",
    "canvasWidth": 360,
    "canvasHeight": 540,
    "maxCanvasWidth": 560,
    "pixelZoom": 2
  },
  "player": {
    "lives": 3,
    "moveSpeed": 200,
    "fireCooldownMs": 160,
    "invulnerableMs": 1000
  },
  "weaponHeat": {
    "enabled": true,
    "maxHeat": 100,
    "heatPerShot": 9,
    "coolPerSecond": 28,
    "overheatLockMs": 2200,
    "ui": {
      "label": "HEAT",
      "x": 8,
      "yOffsetFromBottom": 8,
      "width": 110,
      "height": 10
    }
  },
  "hitboxes": {
    "notes": [
      "Increase widthScale/heightScale to make a hitbox larger relative to sprite size.",
      "Use width/height to force exact pixel dimensions.",
      "minWidth/minHeight guarantee a minimum box size."
    ],
    "player": {
      "widthScale": 2,
      "heightScale": 2,
      "minWidth": 20,
      "minHeight": 20
    },
    "enemy": {
      "widthScale": 4,
      "heightScale": 4
    },
    "playerLaser": {
      "widthScale": 1.5,
      "heightScale": 1.5,
      "minWidth": 8,
      "minHeight": 12
    },
    "enemyLaser": {
      "widthScale": 1.5,
      "heightScale": 1.5,
      "minWidth": 8,
      "minHeight": 11
    }
  },
  "assets": {
    "notes": [
      "Put image files in public/assets/design/ and flip enabled=true for keys you want to use.",
      "Use scale for per-image sizing in Phaser (1 = original size, 0.5 = half size).",
      "When enabled=false or the image is missing, the game falls back to generated placeholder art."
    ],
    "bindings": {
      "playerShip": {
        "category": "player",
        "description": "Player spacecraft sprite",
        "path": "/assets/design/player.png",
        "scale": 0.1,
        "enabled": true
      },
      "playerLaser": {
        "category": "projectile",
        "description": "Player laser projectile",
        "path": "/assets/design/player-laser.png",
        "scale": 1,
        "enabled": false
      },
      "enemyLaser": {
        "category": "projectile",
        "description": "Enemy laser projectile",
        "path": "/assets/design/enemy-laser.png",
        "scale": 1,
        "enabled": false
      },
      "enemyDrone": {
        "category": "enemy",
        "enemyType": "drone",
        "description": "Straight-moving enemy",
        "path": "/assets/design/drone.png",
        "scale": 0.08,
        "enabled": true
      },
      "enemyStriker": {
        "category": "enemy",
        "enemyType": "striker",
        "description": "Zigzag-moving enemy",
        "path": "/assets/design/striker.png",
        "scale": 0.08,
        "enabled": true
      },
      "enemyTurret": {
        "category": "enemy",
        "enemyType": "turret",
        "description": "Stops and shoots",
        "path": "/assets/design/turret.png",
        "scale": 0.1,
        "enabled": true
