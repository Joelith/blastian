        "description": "Sweeping enemy that shoots",
        "path": "/assets/design/gunship.png",
        "scale": 0.1,
        "enabled": true
      }
    }
  },
  "audio": {
    "notes": [
      "Upload .wav files to public/assets/audio/ and point paths here.",
      "Enable music after your background track exists so it loops in-game.",
      "SFX entries can use fallbackTone while no file is configured."
    ],
    "music": {
      "key": "bgMusic",
      "path": "/assets/audio/background.wav",
      "enabled": true,
      "loop": true,
      "volume": 0.35
    },
    "sfx": {
      "playerFire": {
        "key": "sfxPlayerFire",
        "path": "/assets/audio/blast.wav",
        "enabled": true,
        "volume": 0.16,
        "fallbackTone": {
          "enabled": true,
          "type": "square",
          "frequency": 920,
          "attackMs": 3,
          "decayMs": 45,
          "volume": 0.015
